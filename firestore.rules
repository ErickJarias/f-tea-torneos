rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isTournamentOrganizer(tournamentId) {
      return isAuthenticated() && get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.organizerId == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "tatanarias13@gmail.com";
    }

    // Global settings
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Tournament rules
    match /tournaments/{tournamentId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && request.resource.data.organizerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.organizerId) || isAdmin();
      
      // Subcollections
      match /teams/{teamId} {
        allow read: if true;
        allow write: if isTournamentOrganizer(tournamentId);
      }
      
      match /players/{playerId} {
        allow read: if true;
        allow write: if isTournamentOrganizer(tournamentId);
      }
      
      match /matches/{matchId} {
        allow read: if true;
        allow write: if isTournamentOrganizer(tournamentId);
      }
    }
  }
}
